{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "moduleDetection": "force",
    "module": "CommonJS",
    "moduleResolution": "node",
    "verbatimModuleSyntax": false,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src"]
}
